{
  "name": "modern_blue",
  "description": "Modern blue-accent lower-third with slide-up entry",
  "style": {
    "background_opacity": 0.75,
    "background_color": [140, 80, 20],
    "text_color": [255, 255, 255],
    "subtitle_color": [230, 180, 100],
    "font_scale": 1.1,
    "thickness": 2,
    "band_height_ratio": 0.14,
    "animation": "slide_up",
    "animation_duration_ms": 600,
    "exit_animation": "slide_down",
    "exit_animation_duration_ms": 400,
    "easing": "ease_out"
  },
  "layout": {
    "title_offset_x": 50,
    "title_offset_y": 40,
    "subtitle_offset_x": 50,
    "subtitle_offset_y": 80,
    "logo_position": "bottom_left",
    "logo_path": ""
  },
  "transition": {
    "type": "dissolve",
    "duration_ms": 700,
    "easing": "ease_in_out"
  }
}
